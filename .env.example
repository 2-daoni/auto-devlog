# Anthropic API (요약/번역/예제코드 생성)
ANTHROPIC_API_KEY=

# GitHub (Release 수집용, public repo만 쓸 거면 없어도 되지만 rate limit 완화를 위해 권장)
GITHUB_TOKEN=

# DB
DATABASE_URL="file:./dev.db"

# Discord Webhook (파이프라인 결과 알림)
DISCORD_WEBHOOK_URL=

# Tistory (Phase 6 자동 발행 도입 시 사용, 반자동 단계에선 비워둬도 됨)
TISTORY_BLOG_ADDRESS=
TISTORY_LOGIN_ID=
TISTORY_LOGIN_PASSWORD=
