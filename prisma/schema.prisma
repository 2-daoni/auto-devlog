// auto-devlog 데이터 모델
// 파이프라인 각 단계(수집→요약→번역→예제코드→SEO체크→발행)의 상태를 하나의 Post 레코드가 추적합니다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  COLLECTED     // [1] 수집만 된 상태
  SUMMARIZED    // [3] 요약 완료
  TRANSLATED    // [4] 번역 완료
  CODE_ADDED    // [5] 예제코드 보강 완료
  SEO_CHECKED   // [7] SEO 체크 완료, 발행 대기
  PUBLISHED     // [8] 발행 완료
  FAILED        // 파이프라인 중 에러 발생
}

model Post {
  id             String     @id @default(cuid())
  sourceName     String     // ex) "React Blog", "Vercel Blog"
  sourceUrl      String     @unique // 원문 URL, 중복 수집 방지 키
  originalTitle  String
  originalBody   String     // 원문 본문(요약 이전, 필요시 축약 저장)
  publishedAt    DateTime?  // 원문 발행일

  summaryKo      String?    // 한글 요약
  translationKo  String?    // 한글 번역 (풀 번역이 필요한 경우)
  codeExample    String?    // 보강된 예제 코드 (markdown)
  finalDraft     String?    // 최종 포스팅 초안 (markdown, 티스토리 업로드용)

  seoTitleLen    Int?
  seoScore       Int?       // 자체 SEO 체크 점수 (0~100)
  seoIssues      String?    // JSON string, 체크리스트 미통과 항목

  status         PostStatus @default(COLLECTED)
  errorMessage   String?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model PipelineRun {
  id           String   @id @default(cuid())
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  collected    Int      @default(0)
  processed    Int      @default(0)
  failed       Int      @default(0)
  note         String?
}
